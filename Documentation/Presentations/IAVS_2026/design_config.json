{
  "metadata": {
    "name": "IAVS 2026 ORACLE terminal",
    "description": "Single source of truth for the IAVS 2026 RevealJS visual system."
  },
  "palette": {
    "background": "#010301",
    "surface": "#030703",
    "surface_alt": "#071007",
    "border": "#42651D",
    "text": "#B8F77A",
    "muted": "#75A85A",
    "phosphor": "#B8FF6D",
    "amber": "#E2C847",
    "cyan": "#33C9D5",
    "purple": "#C792EA",
    "red": "#FF7B72",
    "shadow": "#000000"
  },
  "typography": {
    "body_family": "'VT323', 'Courier New', monospace",
    "heading_family": "'VT323', 'Courier New', monospace",
    "body_size": "30px",
    "small_size": "25px",
    "heading_weight": "500",
    "body_weight": "400",
    "line_height": "1.42",
    "heading_transform": "uppercase",
    "heading_letter_spacing": "0",
    "terminal_heading_letter_spacing": "0.07em",
    "dialogue_letter_spacing": "0.045em",
    "status_letter_spacing": "0.06em",
    "kicker_size": "0.64em",
    "title_size": "1.75em",
    "title_line_height": "1.15"
  },
  "effects": {
    "screen_scanline_background": "linear-gradient(rgba(141, 245, 154, 0.16) 50%, rgba(0, 0, 0, 0.28) 50%)",
    "screen_border": "1px solid rgba(184, 255, 109, 0.38)",
    "screen_shadow": "inset 0 0 12px rgba(184, 255, 109, 0.035)",
    "title_spotlight_background": "radial-gradient(circle at 22% 18%, rgba(72, 199, 184, 0.18), transparent 30%)",
    "scanline_color": "rgba(184, 255, 109, 0.08)",
    "scanline_size": "4px",
    "scanline_opacity": "0.28",
    "glow": "0 0 6px rgba(184, 255, 109, 0.20)",
    "dim_glow": "0 0 4px rgba(184, 255, 109, 0.10)",
    "cursor_blink_duration": "1.1s",
    "image_blend_mode": "screen",
    "refresh_duration": "180ms",
    "refresh_initial_brightness": "1.8",
    "refresh_peak_brightness": "1.35"
  },
  "spacing": {
    "xs": "0.25rem",
    "sm": "0.5rem",
    "md": "1rem",
    "lg": "1.5rem",
    "xl": "3.2rem"
  },
  "frame": {
    "radius": "0.18rem"
  },
  "sizing": {
    "story_image_max_height": "580px"
  }
